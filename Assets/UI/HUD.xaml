<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Top HUD Bar -->
    <Border Background="#CC000000" VerticalAlignment="Top" Height="60">
        <Grid Margin="20,0,20,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock x:Name="HPText" Text="HP: 100" FontSize="24" FontWeight="Bold" Foreground="#FF4CAF50" VerticalAlignment="Center" Grid.Column="0"/>
            <TextBlock x:Name="ActivePlayerText" Text="Sergeant Miblet's Turn" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center" Grid.Column="1"/>
            <TextBlock x:Name="WeaponText" Text="Weapon: Bazooka" FontSize="24" FontWeight="Bold" Foreground="#FFFF9800" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.Column="2"/>
        </Grid>
    </Border>

    <!-- Turn Timer -->
    <Border Background="#CC000000" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20" CornerRadius="10" Padding="15">
        <TextBlock x:Name="TimerText" Text="Time: 30.0s" FontSize="32" FontWeight="Bold" Foreground="White" />
    </Border>
</Grid>