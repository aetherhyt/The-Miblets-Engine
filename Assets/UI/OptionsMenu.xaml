<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid.Background>
        <SolidColorBrush Color="#FF2C2C2C"/>
    </Grid.Background>

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="600">
        <TextBlock Text="OPTIONS" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        
        <TabControl Background="#FF3C3C3C" Foreground="White" MinHeight="300">
            <!-- Video Tab -->
            <TabItem Header="Video">
                <StackPanel Margin="20">
                    <TextBlock Text="Resolution:" Foreground="White"/>
                    <ComboBox Margin="0,5,0,15">
                        <ComboBoxItem Content="1920x1080"/>
                        <ComboBoxItem Content="1600x900"/>
                        <ComboBoxItem Content="1280x720"/>
                    </ComboBox>
                    <CheckBox Content="Fullscreen" Foreground="White" IsChecked="True" Margin="0,5,0,15"/>
                    <CheckBox Content="Enable V-Sync" Foreground="White" IsChecked="True" Margin="0,5,0,15"/>
                </StackPanel>
            </TabItem>
            
            <!-- Audio Tab -->
            <TabItem Header="Audio">
                <StackPanel Margin="20">
                    <TextBlock Text="Master Volume:" Foreground="White"/>
                    <Slider Minimum="0" Maximum="100" Value="80" Margin="0,5,0,15"/>
                    <TextBlock Text="Effects Volume:" Foreground="White"/>
                    <Slider Minimum="0" Maximum="100" Value="100" Margin="0,5,0,15"/>
                </StackPanel>
            </TabItem>
            
            <!-- Gameplay Tab -->
            <TabItem Header="Gameplay">
                <StackPanel Margin="20">
                    <TextBlock Text="Turn Time Limit:" Foreground="White"/>
                    <ComboBox Margin="0,5,0,15">
                        <ComboBoxItem Content="15 Seconds"/>
                        <ComboBoxItem Content="30 Seconds" IsSelected="True"/>
                        <ComboBoxItem Content="45 Seconds"/>
                    </ComboBox>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Button x:Name="BackButton" Content="BACK" FontSize="20" Margin="0,20,0,0" Padding="10" Background="#FF757575" Foreground="White" BorderThickness="0" HorizontalAlignment="Center" Width="200" />
    </StackPanel>
</Grid>